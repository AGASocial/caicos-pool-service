{
  "expo": {
    "name": "Cadenza",
    "slug": "cadenzaops",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cadenza",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "social.aga.cadenza",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Cadenza uses Face ID to sign you in quickly and lock the app when you switch away.",
        "NSCameraUsageDescription": "Cadenza uses the camera to capture pool service photos for job reports.",
        "NSPhotoLibraryUsageDescription": "Cadenza lets you attach existing photos to service reports.",
        "NSLocationWhenInUseUsageDescription": "Cadenza uses your location to verify on-site service and stamp photos with address."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon-bg.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF7F2",
          "dark": {
            "backgroundColor": "#15191F"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cadenza lets you attach existing photos to service reports.",
          "cameraPermission": "Cadenza uses the camera to capture pool service photos for job reports."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Cadenza uses your location to verify on-site service and stamp photos with address."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f01234f-e107-460e-b09b-9c954e36b185"
      }
    },
    "owner": "agasocial"
  }
}
