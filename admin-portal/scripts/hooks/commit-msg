#!/bin/sh
# Bumps admin-portal/version.json and amends it into the current commit.
set -e

ROOT=$(git rev-parse --show-toplevel)
VERSION_FILE="$ROOT/admin-portal/version.json"

if [ ! -f "$VERSION_FILE" ]; then
  exit 0
fi

# GUI clients (Cursor, VS Code, etc.) run hooks with a minimal PATH — resolve node explicitly.
resolve_node() {
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi

  for candidate in \
    /opt/homebrew/bin/node \
    /usr/local/bin/node
  do
    if [ -x "$candidate" ]; then
      echo "$candidate"
      return 0
    fi
  done

  if [ -f "$HOME/.nvm/alias/default" ]; then
    nvm_default="$HOME/.nvm/versions/node/$(cat "$HOME/.nvm/alias/default")/bin/node"
    if [ -x "$nvm_default" ]; then
      echo "$nvm_default"
      return 0
    fi
  fi

  if [ -d "$HOME/.nvm/versions/node" ]; then
    latest=$(ls -1 "$HOME/.nvm/versions/node" 2>/dev/null | sort -V | tail -1)
    if [ -n "$latest" ] && [ -x "$HOME/.nvm/versions/node/$latest/bin/node" ]; then
      echo "$HOME/.nvm/versions/node/$latest/bin/node"
      return 0
    fi
  fi

  return 1
}

NODE=$(resolve_node) || {
  echo "commit-msg hook: node not found. Install Node.js or run commits from a shell with nvm loaded." >&2
  exit 1
}

"$NODE" "$ROOT/admin-portal/scripts/bump-version.mjs" "$1"
git add "$VERSION_FILE"
git commit --amend --no-edit --no-verify
